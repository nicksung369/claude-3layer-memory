<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude-3layer-memory.viewer</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>python3</string>
        <!-- __HOME__ is replaced by install.sh with the real $HOME at install time -->
        <string>__HOME__/.claude/scripts/memory-viewer/server.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__HOME__/.claude/memory/global/viewer.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.claude/memory/global/viewer.log</string>
</dict>
</plist>
